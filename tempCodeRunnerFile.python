import numpy as np
n = 5
A = np.zeros((n,n),dtype=int)
i = 0
j = n//2
A[i,j] = 1
for x in range(2,n*n+1):
    i = i-1
    j = j+1
    if i<0 and j<=n-1:
        i = n-1
    elif i>=0 and j>n-1:
        j = 0
    elif i<0 and j>n-1:
        i = i+2
        j = n-1
    elif A[i,j] != 0:
        i = i+2
        j = j-1
    A[i,j] = x
print(A)


